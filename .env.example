# Prefer MYSQL_URL for Railway / hosted MySQL:
MYSQL_URL=mysql://user:password@host:port/database

# Or discrete variables:
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=hackathon_db

AUTH_SECRET=change-me-in-production

# URL of the Eco_Hack_AI FastAPI service (used server-side by /api/chat -> /ask).
# Not NEXT_PUBLIC_*: the proxy runs server-side, so the URL stays off the client.
AI_BACKEND_URL=http://127.0.0.1:8000
